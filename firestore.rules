rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    // Check if user has super_admin role (from custom claims set by auth-sync)
    function isSuperAdmin() {
      return signedIn() && request.auth.token.role == 'super_admin';
    }
    
    // Check if user has admin or super_admin role
    function isAdmin() {
      return signedIn() && (
        request.auth.token.role == 'super_admin' || 
        request.auth.token.role == 'admin'
      );
    }

    match /cms/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Audit logs are append-only: only backend can create, no client-side updates/deletes
    match /adminAuditLogs/{logId} {
      allow read: if isAdmin();
      // Create only allowed from backend (authenticated admin users)
      allow create: if false;
      // No updates or deletes allowed - append-only audit trail
      allow update, delete: if false;
    }

    match /adminInvites/{inviteId} {
      allow read, write: if isSuperAdmin();
    }

    match /adminSessions/{sessionId} {
      allow read: if isAdmin();
      allow create, update: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /adminUsers/{userId} {
      allow read: if isAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    match /contactRateLimits/{docId} {
      allow read, write: if true; // typically rate limits are checked by public
    }

    match /mediaItems/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /membershipApplications/{appId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /siteSettings/{settingId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /siteVisitorLogs/{logId} {
      allow read: if isAdmin();
      allow create: if true;
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
