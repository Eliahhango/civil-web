rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return signedIn() && (
        request.auth.uid == '0wirGG8qA3XjkMby3eX62ScE9Ku1' ||
        get(/databases/$(database)/documents/adminUsers/$(request.auth.uid)).data.role == 'super_admin' ||
        request.auth.token.super_admin == true
      );
    }
    
    function isAdmin() {
      return signedIn() && (
        isSuperAdmin() || 
        get(/databases/$(database)/documents/adminUsers/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.token.admin == true
      );
    }

    match /cms/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /adminAuditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if isSuperAdmin();
    }

    match /adminInvites/{inviteId} {
      allow read, write: if isSuperAdmin();
    }

    match /adminSessions/{sessionId} {
      allow read: if isAdmin();
      allow create, update: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /adminUsers/{userId} {
      allow read: if isAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    match /contactRateLimits/{docId} {
      allow read, write: if true; // typically rate limits are checked by public
    }

    match /mediaItems/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /membershipApplications/{appId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /siteSettings/{settingId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /siteVisitorLogs/{logId} {
      allow read: if isAdmin();
      allow create: if true;
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
