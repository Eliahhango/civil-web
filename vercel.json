{
  "outputDirectory": ".",
  "routes": [
    {
      "src": "^/$",
      "status": 307,
      "headers": {
        "Location": "/elitech/home-version-2/"
      }
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^(.*)$",
      "dest": "/elitech/404/index.html",
      "status": 404
    }
  ]
}
