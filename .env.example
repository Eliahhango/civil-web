# Firebase Admin SDK (server-side)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-service-account@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=replace-with-private-key-single-line-escaped-newlines
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_DATABASE_URL=

# CMS admin authorization
# Preferred: set Firebase custom claim admin=true for CMS admins.
# Optional fallback (disabled by default): enable allowlisted admin emails.
CMS_ENABLE_EMAIL_ADMIN_FALLBACK=false
CMS_ADMIN_EMAILS=admin@yourdomain.com,owner@yourdomain.com

# CMS request hard limit in bytes
CMS_MAX_PAYLOAD_BYTES=262144

# Firebase Web SDK (optional client-side)
FIREBASE_WEB_API_KEY=replace-with-web-api-key
FIREBASE_WEB_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_WEB_PROJECT_ID=your-firebase-project-id
FIREBASE_WEB_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_WEB_MESSAGING_SENDER_ID=replace-with-messaging-sender-id
FIREBASE_WEB_APP_ID=replace-with-web-app-id
